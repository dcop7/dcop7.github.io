        <outline text="Fact Check" title="Fact Check">
            <outline type="scrape" text="Polígrafo" title="Polígrafo" xmlUrl="https://poligrafo.sapo.pt/" htmlUrl="https://poligrafo.sapo.pt" match="/fact-check/[a-z0-9-]{6,}"/>
